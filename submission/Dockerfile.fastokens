FROM vllm/vllm-openai:v0.25.1

# fastokens must be installed at image-build time because the grader has no
# network access while the serving container is running.
RUN python3 -m pip install \
      --no-cache-dir \
      --disable-pip-version-check \
      --only-binary=:all: \
      fastokens==0.2.0 \
    && python3 -c "import fastokens; print('fastokens installed:', fastokens.__file__)"
